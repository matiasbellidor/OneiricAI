@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  @apply bg-night text-ivory font-body antialiased;
}

::selection {
  background: rgba(138, 121, 214, 0.35);
}

.eyebrow {
  @apply font-mono text-[11px] uppercase tracking-[0.18em] text-muted;
}

.clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation: none !important;
    transition: none !important;
  }
}
