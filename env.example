"""Dream endpoints: store the raw fragments and their structured extraction."""

from __future__ import annotations

import uuid
from datetime import datetime, timezone

from fastapi import APIRouter, HTTPException

from ..config import settings
from ..db import get_store
from ..models import Dream, DreamIn
from ..services import claude_client

router = APIRouter(tags=["dreams"])


@router.post("/dreams", response_model=Dream)
async def create_dream(body: DreamIn) -> Dream:
    if len(body.text.strip()) < 12:
        raise HTTPException(422, "Contanos un poco m\u00e1s: el relato es demasiado corto para analizar.")
    dream = Dream(
        id=str(uuid.uuid4()),
        user_id=settings.demo_user_id,
        raw_text=body.text.strip(),
        reported_at=datetime.now(timezone.utc),
        structured=await claude_client.extract(body.text),
    )
    get_store().save_dream(dream)
    return dream


@router.get("/dreams/{dream_id}", response_model=Dream)
def get_dream(dream_id: str) -> Dream:
    dream = get_store().get_dream(dream_id)
    if dream is None:
        raise HTTPException(404, "Sue\u00f1o no encontrado.")
    return dream
